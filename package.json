{
  "name": "loom-memory",
  "version": "0.1.2",
  "description": "Weaving ephemeral AI chats into a persistent system mind — an MCP server that turns conversations into structured Markdown knowledge.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "loom": "dist/index.js",
    "loom-cli": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e-opencode": "node tests/e2e-opencode-sandbox/runner.mjs",
    "test:coverage": "vitest run --coverage",
    "test:regression": "bash -lc 'set -o pipefail; mkdir -p .test-logs; vitest run --coverage --reporter=verbose 2>&1 | tee .test-logs/latest.log'",
    "prepublishOnly": "npm run build && npm run test",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "changelog:auto": "tsx scripts/changelog-auto.ts",
    "cli": "node dist/cli.js",
    "sandbox:opencode": "bash scripts/opencode-loom-sandbox/setup.sh",
    "demo:opencode-context-log": "bash scripts/reproduce-opencode-context-log-sample.sh",
    "hooks:install": "bash scripts/hooks-install.sh"
  },
  "keywords": [
    "mcp",
    "loom",
    "ai-memory",
    "markdown",
    "knowledge-base",
    "model-context-protocol"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "prompts",
    "README.md",
    "README.en.md",
    "CHANGELOG.md",
    "INSTALL_POLICY.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "simple-git": "^3.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
